# Cloudflare R2 (S3 API) — used by: npm run r2:scan
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dollworldwide-media
R2_PUBLIC_BASE_URL=https://pub-2332c827c22d490283e3e7585dc5e06c.r2.dev

# Optional: override API URL instead of R2_ACCOUNT_ID
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Optional: comma-separated root prefixes to skip (defaults include DWWD06 + flagship-skin-texture)
# R2_IGNORE_PREFIXES=DWWD06/,flagship-skin-texture/

# Optional: JSON output path (default: scripts/r2-scan-output.json)
# R2_SCAN_OUT=scripts/r2-scan-output.json
